{
  "name": "@neovici/cosmoz-component",
  "version": "1.5.1",
  "description": "Template for Neovici public web components",
  "keywords": [
    "web-components",
    "pion",
    "lit-html"
  ],
  "homepage": "https://github.com/Neovici/cosmoz-component#readme",
  "bugs": {
    "url": "https://github.com/Neovici/cosmoz-component/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Neovici/cosmoz-component.git"
  },
  "license": "Apache-2.0",
  "author": "Neovici Development",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "lint": "tsc && eslint --cache .",
    "check:duplicates": "check-duplicate-components",
    "build": "tsc -p tsconfig.build.json",
    "changeset": "changeset",
    "start": "wds",
    "test": "vitest --run",
    "test:unit": "vitest --project=unit --run",
    "test:storybook": "vitest --project=storybook --run",
    "test:watch": "vitest",
    "storybook:start": "storybook dev -p 8000",
    "storybook:build": "storybook build",
    "storybook:deploy": "storybook-to-ghpages",
    "storybook:preview": "npm run storybook:build && http-server ./storybook-static/ --silent",
    "prepare": "husky"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist/",
    "types"
  ],
  "exports": {
    ".": "./dist/index.js",
    "./cosmoz-component": "./dist/component.js"
  },
  "dependencies": {
    "@pionjs/pion": "^2.5.2",
    "lit-html": "^3.3.1"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@commitlint/cli": "^20.0.0",
    "@commitlint/config-conventional": "^20.0.0",
    "@neovici/cfg": "^2.8.0",
    "@neovici/testing": "^2.3.0",
    "@playwright/test": "^1.60.0",
    "@storybook/addon-docs": "^10.0.0",
    "@storybook/addon-vitest": "^10.2.4",
    "@storybook/web-components-vite": "^10.2.4",
    "@types/node": "^25.5.0",
    "@vitest/browser": "^4.0.18",
    "@vitest/browser-playwright": "^4.0.18",
    "eslint": "^9.0.0",
    "http-server": "^14.1.1",
    "husky": "^9.0.0",
    "jsdom": "^29.0.1",
    "lint-staged": "^17.0.7",
    "shadow-dom-testing-library": "^1.13.1",
    "sinon": "^21.0.3",
    "storybook": "^10.0.0",
    "typescript": "^5.4.3",
    "vitest": "^4.0.18"
  },
  "overrides": {
    "conventional-changelog-conventionalcommits": ">= 8.0.0"
  }
}
